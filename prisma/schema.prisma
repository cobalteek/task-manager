generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String     @id @default(cuid())
  email    String     @unique
  password String
  name     String
  gender   String

  roles     UserRole[]
  tasks     Task[]     @relation("TaskCreatedBy")
  projects  Project[]  @relation("ProjectCreatedBy")
}

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique

  users UserRole[]
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int @default(1)

  @@id([userId, roleId])     // гарантирует уникальность пары
  @@index([roleId])
}

model Status {
  id    Int      @id @default(autoincrement())
  name  String   @unique

  tasks    Task[]
  projects Project[]
}

model Task {
  id        String    @id @default(cuid())
  title     String

  createdAt DateTime  @default(now())
  doneAt    DateTime?

  // status
  status   Status @relation(fields: [statusId], references: [id])
  statusId Int

  // createdBy
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String

  @@index([createdById])
  @@index([statusId])
  @@index([createdAt])
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String?

  createdAt   DateTime  @default(now())
  deadline    DateTime?

  // status
  status   Status @relation(fields: [statusId], references: [id])
  statusId Int

  // createdBy
  createdBy   User   @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String

  @@index([createdById])
  @@index([statusId])
  @@index([deadline])
}
