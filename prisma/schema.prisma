generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String     @id @default(cuid())
  email    String     @unique
  password String
  name     String
  gender   String

  roles     UserRole[]
  handledTasks     Task[]     @relation("TaskHandler")
  projects  Project[]  @relation("ProjectCreatedBy")

  adminProjects AdminProject[]
  userTasks UserTask[]
}

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique

  users UserRole[]
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int @default(1)

  @@id([userId, roleId])     // гарантирует уникальность пары
  @@index([roleId])
}

model Status {
  id    Int      @id @default(autoincrement())
  name  String   @unique

  tasks    Task[]
  projects Project[]
}

model Task {
  id        String    @id @default(cuid())
  title     String
  description String

  createdAt DateTime  @default(now())
  deadline DateTime?
  doneAt    DateTime?

  status   Status @relation(fields: [statusId], references: [id])
  statusId Int

  handler   User   @relation("TaskHandler", fields: [handlerId], references: [id], onDelete: Cascade)
  handlerId String

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String

  participants UserTask[]

  @@index([projectId])
  @@index([handlerId])
  @@index([statusId])
  @@index([createdAt])
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String

  createdAt   DateTime  @default(now())
  deadline    DateTime?
  doneAt    DateTime?

  // status
  status   Status @relation(fields: [statusId], references: [id])
  statusId Int

  // createdBy
  createdBy   User   @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String

  tasks Task[]
  admins AdminProject[]

  @@index([createdById])
  @@index([statusId])
  @@index([deadline])
}

model AdminProject {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@id([userId, projectId])
  @@index([projectId])
}

model UserTask {
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  @@id([userId, taskId])
  @@index([taskId])
}
